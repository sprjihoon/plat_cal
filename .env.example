# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 사이트 URL (프로덕션 배포 시 필수)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── 카카오 로그인 ──
# Supabase Dashboard → Authentication → Providers → Kakao 에서 설정
# 1. https://developers.kakao.com 에서 애플리케이션 생성
# 2. REST API 키 → Supabase Kakao Provider의 Client ID에 입력
# 3. 카카오 개발자 콘솔 → 제품 설정 → 카카오 로그인 → 활성화
# 4. Redirect URI: https://your-project.supabase.co/auth/v1/callback
# 5. 동의항목: 닉네임, 프로필 사진, 이메일 (선택)

# ── 네이버 로그인 ──
# 1. https://developers.naver.com/apps 에서 애플리케이션 등록
# 2. 사용 API: 네이버 로그인 (네아로)
# 3. 서비스 URL: https://your-domain.com
# 4. Callback URL: https://your-domain.com/api/auth/naver/callback
#    (로컬 개발: http://localhost:3000/api/auth/naver/callback)
# 5. 제공 정보: 이름, 이메일, 프로필 사진
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
